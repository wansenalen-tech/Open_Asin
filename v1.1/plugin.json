{
  "name": "打开Asin",
  "version": "1.0.0",
  "pluginName": "打开Asin",
  "description": "通过Chrome打开亚马逊Asin对应的页面",
"preload": "preload.js",
  "logo": "logo.png",
  "features": [
    {
      "code": "demo_match_text",
      "explain": "智能匹配文本示例",
      "cmds": [
        "match_text",
        {
          "type": "regex",
          "label": "打开亚马逊",
          "match": "/^https://www.amazon.com/.*$/"
        },
        {
          "type": "regex",
          "label": "打开Asin网页", 
          "match": "/^B0.*$/"
        }
      ]
    }
  ]
}
